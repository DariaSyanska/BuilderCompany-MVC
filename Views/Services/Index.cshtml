@model IEnumerable<BuilderCompany.Models.Service>
@{
    ViewData["Title"] = "Управління послугами";
}

<div class="container mt-5" style="min-height: 60vh;">
    <h2 class="mb-4">Управління послугами (CRUD)</h2>
    
    <button class="btn btn-success mb-3">➕ Додати нову послугу</button>
    
    <div class="table-responsive">
        <table class="table table-bordered table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th class="text-center">Іконка</th>
                    <th>Назва послуги</th>
                    <th>Опис</th>
                    <th class="text-center">Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fs-4 text-center">@item.IconClass</td>
                        <td class="fw-bold">@item.Title</td>
                        <td>@item.Description</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-primary me-1">✏️ Редагувати</button>
                            <button class="btn btn-sm btn-danger">🗑️ Видалити</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>