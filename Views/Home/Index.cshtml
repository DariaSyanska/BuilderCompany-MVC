@model BuilderCompany.Models.HomeViewModel
@{
    ViewData["Title"] = "Головна";
}

<div class="p-5 mb-4 bg-dark text-white rounded-3 shadow" style="background-image: url('https://images.unsplash.com/photo-1503387762-592deb58ef4e?w=1200'); background-size: cover; background-position: center;">
    <div class="container-fluid py-5" style="background-color: rgba(0,0,0,0.6); border-radius: 10px;">
        <h1 class="display-5 fw-bold">Builder Company</h1>
        <p class="col-md-8 fs-4">Ваш надійний партнер у будівництві. Ми створюємо майбутнє, будуючи надійні та сучасні об'єкти для життя та бізнесу.</p>
        <button class="btn btn-primary btn-lg" type="button" data-bs-toggle="modal" data-bs-target="#orderModal">Замовити проект</button>
    </div>
</div>

<div class="container px-4 py-5">
    <h2 class="pb-2 border-bottom text-center mb-4">Наші послуги</h2>
    <div class="row g-4 py-5 row-cols-1 row-cols-lg-3">
        @foreach (var item in Model.Services)
        {
            <div class="col d-flex align-items-start">
                <div class="icon-square text-body-emphasis bg-body-secondary d-inline-flex align-items-center justify-content-center fs-4 flex-shrink-0 me-3 p-3 rounded-circle">
                    @item.IconClass
                </div>
                <div>
                    <h3 class="fs-2 text-body-emphasis">@item.Title</h3>
                    <p>@item.Description</p>
                </div>
            </div>
        }
    </div>
</div>

<div class="container px-4 py-5 bg-light rounded shadow-sm">
    <h2 class="pb-2 border-bottom text-center mb-4">Останні проекти</h2>
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var project in Model.Projects)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <img src="@project.ImageUrl" class="card-img-top" alt="@project.Name" style="height: 250px; object-fit: cover;">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">@project.Name</h5>
                        <p class="card-text text-muted"><small>📍 @project.Location | 📅 @project.YearCompleted рік</small></p>
                        <p class="card-text">@project.Description</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="orderModal" tabindex="-1" aria-labelledby="orderModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="orderModalLabel">Замовлення проекту</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="mb-3">
                        <label for="clientName" class="form-label">Ваше ім'я</label>
                        <input type="text" class="form-control" id="clientName" placeholder="Наприклад, Олена">
                    </div>
                    <div class="mb-3">
                        <label for="clientPhone" class="form-label">Номер телефону</label>
                        <input type="tel" class="form-control" id="clientPhone" placeholder="+38 (000) 000-00-00">
                    </div>
                    <div class="mb-3">
                        <label for="clientMessage" class="form-label">Який проект вас цікавить?</label>
                        <textarea class="form-control" id="clientMessage" rows="3" placeholder="Коротко опишіть ваші побажання..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal" onclick="alert('Дякуємо! Ваша заявка успішно надіслана. Наш менеджер зателефонує вам найближчим часом.')">Відправити заявку</button>
            </div>
        </div>
    </div>
</div>