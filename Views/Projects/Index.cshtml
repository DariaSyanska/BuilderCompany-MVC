@model IEnumerable<BuilderCompany.Models.Project>
@{
    ViewData["Title"] = "Управління проектами";
}

<div class="container mt-5" style="min-height: 60vh;">
    <h2 class="mb-4">Управління проектами (CRUD)</h2>
    
    <button class="btn btn-success mb-3">➕ Додати новий проект</button>
    
    <div class="table-responsive">
        <table class="table table-bordered table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Назва об'єкта</th>
                    <th>Локація</th>
                    <th>Рік здачі</th>
                    <th class="text-center">Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-bold">@item.Name</td>
                        <td>@item.Location</td>
                        <td>@item.YearCompleted</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-primary me-1">✏️ Редагувати</button>
                            <button class="btn btn-sm btn-danger">🗑️ Видалити</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>